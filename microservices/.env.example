# ═══════════════════════════════════════════════════════════════════════════
# HMS Microservices — Environment Variables
# Copy this to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════

# ── JWT Secret (all services share the same key) ───────────────────────────
JWT_SECRET=your-very-long-secret-key-at-least-64-chars-long-for-HS512-algorithm

# ── Email / Gmail ──────────────────────────────────────────────────────────
MAIL_USERNAME=priyanshjais123@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ── Google OAuth2 ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Kafka (Confluent Cloud in production) ──────────────────────────────────
# For local Docker: kafka:29092
# For Confluent Cloud: pkc-xxxxx.region.gcp.confluent.cloud:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Neon PostgreSQL (one URL per service database) ─────────────────────────
# Format: jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/DATABASE?sslmode=require
AUTH_DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/hms_auth?sslmode=require
DOCTOR_DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/hms_doctor?sslmode=require
PATIENT_DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/hms_patient?sslmode=require
APPOINTMENT_DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/hms_appointment?sslmode=require
CLINICAL_DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/hms_clinical?sslmode=require
PHARMACY_DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/hms_pharmacy?sslmode=require
BILLING_DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/hms_billing?sslmode=require
DB_USERNAME=your-neon-username
DB_PASSWORD=your-neon-password

# ── Render Service URLs (for inter-service communication) ──────────────────
AUTH_SERVICE_URL=https://hms-auth.onrender.com
DOCTOR_SERVICE_URL=https://hms-doctor.onrender.com
PATIENT_SERVICE_URL=https://hms-patient.onrender.com
APPOINTMENT_SERVICE_URL=https://hms-appointment.onrender.com
BILLING_SERVICE_URL=https://hms-billing.onrender.com
PHARMACY_SERVICE_URL=https://hms-pharmacy.onrender.com
CLINICAL_SERVICE_URL=https://hms-clinical.onrender.com
ADMIN_SERVICE_URL=https://hms-admin.onrender.com
