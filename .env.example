# =============================================================================
#  Priyansh Care Hospital — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to git!
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password_here

# ── JWT Secret (same value used in ALL microservices) ─────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_key_here_min_64_chars

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Eureka ────────────────────────────────────────────────────────────────────
EUREKA_HOST=localhost
EUREKA_USERNAME=admin
EUREKA_PASSWORD=admin

# ── Google OAuth2 (auth-service) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8089/login/oauth2/code/google

# ── Gmail SMTP (notification-service) ────────────────────────────────────────
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ── Groq AI API (clinical-service) ───────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Service Hosts (override for production/Docker) ───────────────────────────
AUTH_SERVICE_HOST=localhost
DOCTOR_SERVICE_HOST=localhost
APPOINTMENT_SERVICE_HOST=localhost
PATIENT_SERVICE_HOST=localhost
BILLING_SERVICE_HOST=localhost
PHARMACY_SERVICE_HOST=localhost
CLINICAL_SERVICE_HOST=localhost
ADMIN_SERVICE_HOST=localhost

# ── Frontend URL ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Zipkin Tracing (optional) ─────────────────────────────────────────────────
ZIPKIN_HOST=localhost
